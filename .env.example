# Supabase 설정
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# OpenAI 설정 (Supabase Edge Function에서 사용 — supabase secrets set OPENAI_API_KEY=sk-...)
# VITE_OPENAI_API_KEY는 더 이상 필요 없습니다

# 관리자 이메일 (설정 시 해당 이메일만 /admin 접근 허용, 미설정 시 로그인 사용자 전체 허용)
VITE_ADMIN_EMAIL=admin@example.com

# 앱 설정
VITE_APP_NAME=스마트케어나비
VITE_APP_ENV=development
